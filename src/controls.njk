---
title: Controls
layout: layout/base.njk
---

<h1 class="page-heading">Control Room</h1>

<div class="ui segment">

    <p class="page-heading">Concern Codes</p>

    <div class="ui list" id="concern-list">
        {% for item in concern_codes %}
        <div class="item" data-code-id="{{ item.id }}" {% if item.disabled %}style="opacity: 0.5;" {% endif %}>
            <div class="content">
                <div class="header">
                    {{ item.label }}
                    {% if item.disabled %}<span style="color: var(--red); font-size: 0.6rem; letter-spacing: 0.08em; margin-left: 0.5rem;">DISABLED</span>{% endif %}
                </div>
            </div>
            <div class="ui mini toggle checkbox">
                <input type="checkbox" class="code-toggle" data-code-id="{{ item.id }}" {% if not item.disabled %}checked{% endif %}>
                <label></label>
            </div>
        </div>
        {% endfor %}
    </div>

    <div class="ui tiny message">
        Format: <strong>Department-Concern</strong> &mdash; e.g. <code>OMT-Delay</code>, <code>OMT-NA</code><br>
        Avoid spaces and special characters. Use hyphens or underscores only.
    </div>

    <form id="add-label-form">
        <input type="text" id="new-label" name="newLabel" placeholder="e.g., OMT-URGENT" required>
        <button type="submit" id="submit-btn">+ Add Code</button>
    </form>

    <p id="status-message" style="display:none;"></p>

</div>

<script src="/assets/js/controls.js"></script>