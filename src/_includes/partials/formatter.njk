<p class="page-heading">Formatter</p>

<form action="" id="template_form" class="ui inverted mini form">

  {# Full Name Field #}
  <div class="ui inverted transparent  field">
    <label for="full_name">Full Name:</label>
    <input type="text" id="full_name" name="Full Name"  required/>
  </div>

  {# Phone Number Field #}
  <div class="field">
    <label for="phone_number">Phone Number:</label>
    <input type="number" id="phone_number" name="Phone Number" required />
  </div>

  <div class="field">

    <label for="concern_select">Concern</label>
    <select class="ui fluid dropdown inverted" name="Concern" id="concern_select" required>

      <option value="" selected>Select Concern</option>
      
      {% for item in concern_codes %}
      {% if not item.disabled %}
        <option value="{{ item.label }}">{{ item.label }}</option>
      {% endif %}
      {% endfor %}
    </select>

  </div>

  <div class="mini two ui buttons" id="button_group">

    <button type="button" id="showValueBtn" class="ui button" onClick="runShowValues()">
      Convert
    </button>
    <button type="button" class="ui button negative" onclick="clearConverterForm()">Clear</button>

  </div>
</form>


<div class="ui basic segments" id="ui_feedback">

  <div class="ui blue segment">
    <p id="display_value">
      Full Name: <br>
      Phone Number: <br>
      Concern:
    </p>
  </div>
</div>

<button class="ui mini primary button btn" data-clipboard-target="#display_value">
  <i class="ui icon clipboard"></i>Copy to Clipboard
</button>


<script defer>
  const templateFormRules = {
  full_name: {
    identifier: 'full_name',
    rules: [{ type: 'empty', prompt: 'Full Name is required' }]
  },
  phone_number: {
    identifier: 'phone_number',
    rules: [
      { type: 'empty', prompt: 'Phone Number is required' },
      { type: 'integer', prompt: 'Must be a valid number' }
    ]
  },
  concern_select: {
    identifier: 'concern_select',
    rules: [{ type: 'empty', prompt: 'Please select a concern' }]
  }
};

// Wire up on page load
const runShowValues = FormValidator.init(
  'template_form',
  templateFormRules,
  showValues, // your existing function
  'showvalueBtn'
);
</script>
